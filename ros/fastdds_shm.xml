<?xml version="1.0" encoding="UTF-8" ?>
<!-- Fast DDS transport profile: large shared-memory segment for big LiDAR point clouds.

     WHY: an Ouster 1024x128 cloud is ~6 MB. Fast DDS's default shared-memory segment is
     ~512 KB, far too small for one cloud, so it silently falls back to UDP. Best-effort UDP
     then needs a socket receive buffer >= one cloud, but net.core.rmem_max defaults to 4 MB
     (< 6 MB) — so whole clouds are lost in fragment reassembly. Measured effect: a bare
     subscriber received only 109/325 clouds (~66% loss), independent of playback rate.

     FIX: a 64 MB SHM segment lets clouds transfer via shared memory (no UDP fragmentation,
     no dependence on net.core.rmem_max). Bare subscriber then received 325/325; the full
     elevation_node went from 136/325 processed (58% dropped, ICP rejects) to 318/325 (2%,
     0 rejects). Same-host only (bag+node on one machine); for multi-host, raise
     net.core.rmem_max above the cloud size instead (needs root).

     USE: point EVERY participant (publisher AND subscriber) at this file:
       export FASTRTPS_DEFAULT_PROFILES_FILE=<repo>/ros/fastdds_shm.xml
     The elevation-demo tmuxinator sets this in every pane. -->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>shm_big</transport_id>
        <type>SHM</type>
        <segment_size>67108864</segment_size>
      </transport_descriptor>
      <transport_descriptor>
        <transport_id>udp_fallback</transport_id>
        <type>UDPv4</type>
      </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="big_shm_participant" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>shm_big</transport_id>
          <transport_id>udp_fallback</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
